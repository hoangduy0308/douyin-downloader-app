{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Douyin Downloader App",
  "version": "0.1.0",
  "identifier": "com.hdi.douyindownloaderapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Douyin Downloader",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
